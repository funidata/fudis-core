{
  "name": "@funidata/fudis-core",
  "version": "3.0.0",
  "private": "true",
  "workspaces": [
    "core",
    "tests"
  ],
  "scripts": {
    "start:storybook": "docker compose up --build -d core-storybook",
    "test": "cd ngx-fudis && npm test",
    "test:vr": "docker compose run --service-ports core-vr npx playwright test",
    "test:vr-report": "docker compose run --service-ports core-vr npx playwright show-report --host 0.0.0.0",
    "test:ui": "find tests/visual-regression -name \\*-darwin.png -type f -delete && cd tests && npm run test:ui",
    "stop": "docker compose down",
    "stylelint": "stylelint '**/*.{css,scss}'",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "version": "scripts/version_sub_projects.sh $npm_package_version",
    "postversion": "git commit --amend -m \"Bump to version v$npm_package_version\""
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "stylelint": "^16.26.1",
    "stylelint-config-concentric-order": "^5.3.0",
    "stylelint-config-standard-scss": "^14.0.0"
  },
  "dependencies": {
    "@types/node": "^25.3.3"
  }
}
